@model IEnumerable<M5Storage.Models.Movimentacao>
@{
    ViewData["Title"] = "Movimentações";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title"><i class="fas fa-exchange-alt"></i>Movimentações</h1>
        <p style="color:var(--text-muted); font-size:0.78rem; letter-spacing:1px; margin-top:4px;">Consumo e reabastecimento de suprimentos</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Home" asp-action="Index" class="btn-m5-secondary"><i class="fas fa-arrow-left me-1"></i>Dashboard</a>
        <a asp-action="Create" class="btn-m5-success"><i class="fas fa-plus me-1"></i>Nova Movimentação</a>
    </div>
</div>

<div class="card-m5">
    <table class="table table-m5 mb-0">
        <thead>
            <tr>
                <th>#ID</th>
                <th>Recurso</th>
                <th>Usuário</th>
                <th>Tipo</th>
                <th>Quantidade</th>
                <th>Descrição</th>
                <th>Data</th>
                <th style="text-align:center;">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var tipoClass = item.TipoMovimentacao?.ToUpper() == "CONSUMO" ? "badge-critico" : "badge-normal";
                <tr>
                    <td style="color:var(--text-muted); font-size:0.8rem;">#@item.Id</td>
                    <td><strong>@(item.Recurso?.Nome ?? "—")</strong></td>
                    <td style="color:var(--text-muted);">@(item.Usuario?.Nome ?? "—")</td>
                    <td><span class="@tipoClass">@item.TipoMovimentacao</span></td>
                    <td>@item.Quantidade</td>
                    <td style="color:var(--text-muted); font-size:0.85rem;">@(item.Descricao ?? "—")</td>
                    <td style="color:var(--text-muted); font-size:0.8rem;">@(item.DataMovimentacao?.ToString("dd/MM/yy HH:mm") ?? "—")</td>
                    <td style="text-align:center;">
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-m5-danger">
                            <i class="fas fa-trash me-1"></i>Excluir
                        </a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" style="text-align:center; color:var(--text-muted); padding:2rem;">
                        <i class="fas fa-inbox fa-2x mb-2" style="display:block; opacity:0.3;"></i>
                        Nenhuma movimentação registrada.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
