<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — M5-Storage</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        :root {
            --neon-cyan: #00e5ff;
            --neon-blue: #1565ff;
            --neon-red: #ff1744;
            --neon-green: #00e676;
            --neon-yellow: #ffea00;
            --bg-dark: #050b14;
            --bg-panel: #0a1628;
            --bg-card: #0d1f3c;
            --border-glow: rgba(0, 229, 255, 0.25);
            --text-primary: #e0f7ff;
            --text-muted: #6c8fa8;
        }

        * { box-sizing: border-box; }

        body {
            background-color: var(--bg-dark);
            color: var(--text-primary);
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
            background-image:
                radial-gradient(ellipse at 20% 50%, rgba(21, 101, 255, 0.06) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(0, 229, 255, 0.04) 0%, transparent 50%);
        }

        .navbar-m5 {
            background: rgba(5, 11, 20, 0.95);
            border-bottom: 1px solid var(--border-glow);
            backdrop-filter: blur(12px);
            padding: 0.75rem 1.5rem;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .navbar-brand-m5 {
            font-size: 1.3rem;
            font-weight: 700;
            letter-spacing: 2px;
            color: var(--neon-cyan) !important;
            text-decoration: none;
            text-transform: uppercase;
        }

        .navbar-brand-m5 span {
            color: var(--neon-blue);
        }

        .nav-link-m5 {
            color: var(--text-muted) !important;
            font-size: 0.82rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 0.5rem 1rem !important;
            transition: color 0.2s, text-shadow 0.2s;
        }

        .nav-link-m5:hover, .nav-link-m5.active {
            color: var(--neon-cyan) !important;
            text-shadow: 0 0 8px rgba(0, 229, 255, 0.6);
        }

        .nav-link-m5 i { margin-right: 6px; }

        .main-content {
            padding: 2rem 1.5rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .card-m5 {
            background: var(--bg-card);
            border: 1px solid var(--border-glow);
            border-radius: 8px;
            transition: border-color 0.3s, box-shadow 0.3s;
        }

        .card-m5:hover {
            border-color: rgba(0, 229, 255, 0.5);
            box-shadow: 0 0 20px rgba(0, 229, 255, 0.08);
        }

        .card-header-m5 {
            background: rgba(0, 229, 255, 0.05);
            border-bottom: 1px solid var(--border-glow);
            padding: 1rem 1.5rem;
            border-radius: 8px 8px 0 0;
        }

        .table-m5 {
            color: var(--text-primary);
            border-color: var(--border-glow);
        }

        .table-m5 thead th {
            background: rgba(0, 229, 255, 0.06);
            border-color: var(--border-glow);
            color: var(--neon-cyan);
            font-size: 0.78rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-weight: 600;
            padding: 0.9rem 1rem;
        }

        .table-m5 tbody tr {
            border-color: var(--border-glow);
            transition: background 0.2s;
        }

        .table-m5 tbody tr:hover {
            background: rgba(0, 229, 255, 0.03);
        }

        .table-m5 tbody td {
            border-color: var(--border-glow);
            vertical-align: middle;
            padding: 0.75rem 1rem;
            font-size: 0.9rem;
        }

        .btn-m5-primary {
            background: transparent;
            border: 1px solid var(--neon-cyan);
            color: var(--neon-cyan);
            font-size: 0.8rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 0.45rem 1.1rem;
            border-radius: 4px;
            transition: all 0.25s;
        }

        .btn-m5-primary:hover {
            background: var(--neon-cyan);
            color: var(--bg-dark);
            box-shadow: 0 0 16px rgba(0, 229, 255, 0.4);
        }

        .btn-m5-success {
            background: transparent;
            border: 1px solid var(--neon-green);
            color: var(--neon-green);
            font-size: 0.8rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 0.45rem 1.1rem;
            border-radius: 4px;
            transition: all 0.25s;
        }

        .btn-m5-success:hover {
            background: var(--neon-green);
            color: var(--bg-dark);
            box-shadow: 0 0 16px rgba(0, 230, 118, 0.4);
        }

        .btn-m5-warning {
            background: transparent;
            border: 1px solid var(--neon-yellow);
            color: var(--neon-yellow);
            font-size: 0.8rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 0.45rem 1.1rem;
            border-radius: 4px;
            transition: all 0.25s;
        }

        .btn-m5-warning:hover {
            background: var(--neon-yellow);
            color: var(--bg-dark);
            box-shadow: 0 0 16px rgba(255, 234, 0, 0.4);
        }

        .btn-m5-danger {
            background: transparent;
            border: 1px solid var(--neon-red);
            color: var(--neon-red);
            font-size: 0.8rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 0.45rem 1.1rem;
            border-radius: 4px;
            transition: all 0.25s;
        }

        .btn-m5-danger:hover {
            background: var(--neon-red);
            color: #fff;
            box-shadow: 0 0 16px rgba(255, 23, 68, 0.4);
        }

        .btn-m5-secondary {
            background: transparent;
            border: 1px solid var(--text-muted);
            color: var(--text-muted);
            font-size: 0.8rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 0.45rem 1.1rem;
            border-radius: 4px;
            transition: all 0.25s;
        }

        .btn-m5-secondary:hover {
            background: var(--text-muted);
            color: var(--bg-dark);
        }

        .form-control-m5, .form-select-m5 {
            background: rgba(5, 11, 20, 0.8);
            border: 1px solid var(--border-glow);
            color: var(--text-primary);
            border-radius: 4px;
            padding: 0.55rem 0.9rem;
            font-size: 0.9rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-control-m5:focus, .form-select-m5:focus {
            background: rgba(5, 11, 20, 0.9);
            border-color: var(--neon-cyan);
            box-shadow: 0 0 0 3px rgba(0, 229, 255, 0.12);
            color: var(--text-primary);
            outline: none;
        }

        .form-control-m5::placeholder { color: var(--text-muted); }

        .form-select-m5 option {
            background: var(--bg-panel);
            color: var(--text-primary);
        }

        .form-label-m5 {
            font-size: 0.78rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 0.35rem;
        }

        .page-title {
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--neon-cyan);
            margin-bottom: 0;
        }

        .page-title i { margin-right: 10px; opacity: 0.8; }

        .badge-critico {
            background: rgba(255, 23, 68, 0.15);
            color: var(--neon-red);
            border: 1px solid rgba(255, 23, 68, 0.4);
            font-size: 0.72rem;
            letter-spacing: 1px;
            padding: 0.3rem 0.65rem;
            border-radius: 3px;
        }

        .badge-normal {
            background: rgba(0, 230, 118, 0.12);
            color: var(--neon-green);
            border: 1px solid rgba(0, 230, 118, 0.35);
            font-size: 0.72rem;
            letter-spacing: 1px;
            padding: 0.3rem 0.65rem;
            border-radius: 3px;
        }

        .badge-baixo {
            background: rgba(255, 234, 0, 0.12);
            color: var(--neon-yellow);
            border: 1px solid rgba(255, 234, 0, 0.35);
            font-size: 0.72rem;
            letter-spacing: 1px;
            padding: 0.3rem 0.65rem;
            border-radius: 3px;
        }

        .badge-alto {
            background: rgba(21, 101, 255, 0.15);
            color: #82b1ff;
            border: 1px solid rgba(21, 101, 255, 0.4);
            font-size: 0.72rem;
            letter-spacing: 1px;
            padding: 0.3rem 0.65rem;
            border-radius: 3px;
        }

        .alert-m5-success {
            background: rgba(0, 230, 118, 0.08);
            border: 1px solid rgba(0, 230, 118, 0.3);
            color: var(--neon-green);
            border-radius: 6px;
            padding: 0.75rem 1.2rem;
            font-size: 0.88rem;
        }

        .alert-m5-danger {
            background: rgba(255, 23, 68, 0.08);
            border: 1px solid rgba(255, 23, 68, 0.3);
            color: #ff6090;
            border-radius: 6px;
            padding: 0.75rem 1.2rem;
            font-size: 0.88rem;
        }

        .footer-m5 {
            border-top: 1px solid var(--border-glow);
            padding: 1.2rem 1.5rem;
            text-align: center;
            font-size: 0.75rem;
            color: var(--text-muted);
            letter-spacing: 1px;
            margin-top: 4rem;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(0, 229, 255, 0.008) 2px,
                rgba(0, 229, 255, 0.008) 4px
            );
            pointer-events: none;
            z-index: 9999;
        }

        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border-glow);
            border-radius: 8px;
            padding: 1.5rem;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
        }

        .stat-card-cyan::before { background: linear-gradient(90deg, transparent, var(--neon-cyan), transparent); }
        .stat-card-green::before { background: linear-gradient(90deg, transparent, var(--neon-green), transparent); }
        .stat-card-yellow::before { background: linear-gradient(90deg, transparent, var(--neon-yellow), transparent); }
        .stat-card-red::before { background: linear-gradient(90deg, transparent, var(--neon-red), transparent); }
        .stat-card-blue::before { background: linear-gradient(90deg, transparent, #82b1ff, transparent); }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 30px rgba(0, 229, 255, 0.08);
            border-color: rgba(0, 229, 255, 0.4);
        }

        .stat-number {
            font-size: 2.4rem;
            font-weight: 700;
            line-height: 1;
            margin-bottom: 0.4rem;
        }

        .stat-label {
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .stat-icon {
            font-size: 2rem;
            opacity: 0.2;
            position: absolute;
            right: 1.5rem;
            top: 50%;
            transform: translateY(-50%);
        }

        .navbar-toggler-m5 {
            border: 1px solid var(--border-glow);
            background: transparent;
            color: var(--neon-cyan);
            padding: 0.35rem 0.7rem;
            border-radius: 4px;
        }
    </style>
</head>
<body>
    <nav class="navbar-m5 d-flex align-items-center justify-content-between flex-wrap gap-2">
        <a class="navbar-brand-m5" asp-controller="Home" asp-action="Index">
            ⬡ M5<span>-Storage</span>
        </a>

        <div class="d-flex flex-wrap gap-1 align-items-center">
            <a class="nav-link-m5" asp-controller="Home" asp-action="Index">
                <i class="fas fa-satellite-dish"></i>Dashboard
            </a>
            <a class="nav-link-m5" asp-controller="Usuarios" asp-action="Index">
                <i class="fas fa-user-astronaut"></i>Usuários
            </a>
            <a class="nav-link-m5" asp-controller="Recursos" asp-action="Index">
                <i class="fas fa-database"></i>Recursos
            </a>
            <a class="nav-link-m5" asp-controller="Movimentacoes" asp-action="Index">
                <i class="fas fa-exchange-alt"></i>Movimentações
            </a>
            <a class="nav-link-m5" asp-controller="Alertas" asp-action="Index">
                <i class="fas fa-bell"></i>Alertas
            </a>
        </div>
    </nav>

    <div class="main-content">
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert-m5-success mb-3">
                <i class="fas fa-check-circle me-2"></i>@TempData["Sucesso"]
            </div>
        }

        @RenderBody()
    </div>

    <footer class="footer-m5">
        &copy; 2026 — M5-Storage &nbsp;|&nbsp; Sistema de Gestão de Recursos Espaciais
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
