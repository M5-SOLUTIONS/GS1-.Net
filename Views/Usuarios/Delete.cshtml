@model M5Storage.Models.Usuario
@{
    ViewData["Title"] = "Remover Usuário";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title" style="color:var(--neon-red);"><i class="fas fa-user-slash"></i>Remover Usuário</h1>
    <a asp-action="Index" class="btn-m5-secondary"><i class="fas fa-arrow-left me-1"></i>Voltar</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card-m5" style="border-color: rgba(255,23,68,0.35);">
            <div style="background:rgba(255,23,68,0.06); border-bottom:1px solid rgba(255,23,68,0.25); padding:1rem 1.5rem; border-radius:8px 8px 0 0;">
                <i class="fas fa-exclamation-triangle" style="color:var(--neon-red);"></i>
                <span style="color:#ff6090; margin-left:8px; font-size:0.85rem; letter-spacing:1px; text-transform:uppercase;">
                    Ação irreversível — confirme a remoção
                </span>
            </div>
            <div class="p-4">
                <dl style="margin:0;">
                    <dt class="form-label-m5">Nome</dt>
                    <dd style="color:var(--text-primary); margin-bottom:0.8rem;">@Model.Nome</dd>
                    <dt class="form-label-m5">Email</dt>
                    <dd style="color:var(--text-primary); margin-bottom:0.8rem;">@Model.Email</dd>
                </dl>
            </div>
            <div class="p-4 d-flex gap-2" style="border-top:1px solid var(--border-glow);">
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn-m5-danger"><i class="fas fa-trash me-1"></i>Confirmar Remoção</button>
                </form>
                <a asp-action="Index" class="btn-m5-secondary">Cancelar</a>
            </div>
        </div>
    </div>
</div>
