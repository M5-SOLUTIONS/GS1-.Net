@model M5Storage.Models.Recurso
@{
    ViewData["Title"] = "Novo Recurso";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title"><i class="fas fa-plus-circle"></i>Novo Recurso</h1>
    <a asp-action="Index" class="btn-m5-secondary"><i class="fas fa-arrow-left me-1"></i>Voltar</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card-m5 p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert-m5-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-8 mb-3">
                        <label class="form-label-m5">Nome do Recurso</label>
                        <input asp-for="Nome" class="form-control-m5 w-100" placeholder="Ex: Oxigênio Primário" />
                        <span asp-validation-for="Nome" style="color:#ff6090; font-size:0.78rem;"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label-m5">Categoria</label>
                        <select asp-for="Categoria" id="categoriaSelect" class="form-select-m5 w-100">
                            <option value="">Selecione...</option>
                            <option value="AGUA">Água</option>
                            <option value="OXIGENIO">Oxigênio</option>
                            <option value="ENERGIA">Energia</option>
                            <option value="MEDICAMENTO">Medicamento</option>
                            <option value="ALIMENTO">Alimento</option>
                        </select>
                        <span asp-validation-for="Categoria" style="color:#ff6090; font-size:0.78rem;"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label-m5">Quantidade Atual</label>
                        <input asp-for="Quantidade" type="number" step="0.01" class="form-control-m5 w-100" placeholder="0.00" />
                        <span asp-validation-for="Quantidade" style="color:#ff6090; font-size:0.78rem;"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label-m5">Mínimo Seguro</label>
                        <input asp-for="Minimo" type="number" step="0.01" class="form-control-m5 w-100" placeholder="0.00" />
                        <span asp-validation-for="Minimo" style="color:#ff6090; font-size:0.78rem;"></span>
                    </div>
                </div>

                <div id="campoEnergia" class="mb-3" style="display:none;">
                    <label class="form-label-m5">Tipo de Energia</label>
                    <select name="TipoEnergia" class="form-select-m5 w-100">
                        <option value="">Selecione...</option>
                        <option value="SOLAR">Solar</option>
                        <option value="NUCLEAR">Nuclear</option>
                        <option value="BATERIA">Bateria</option>
                        <option value="COMBUSTIVEL">Combustível</option>
                    </select>
                </div>

                <div id="campoMedicamento" class="mb-3" style="display:none;">
                    <label class="form-label-m5">Validade</label>
                    <input type="date" name="Validade" class="form-control-m5 w-100" />
                </div>

                <div class="d-flex gap-2 mt-2">
                    <button type="submit" class="btn-m5-success"><i class="fas fa-check me-1"></i>Registrar Recurso</button>
                    <a asp-action="Index" class="btn-m5-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.getElementById('categoriaSelect').addEventListener('change', function () {
            var val = this.value.toUpperCase();
            document.getElementById('campoEnergia').style.display = (val === 'ENERGIA') ? 'block' : 'none';
            document.getElementById('campoMedicamento').style.display = (val === 'MEDICAMENTO') ? 'block' : 'none';
        });
    </script>
}
